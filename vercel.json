{
  "version": 2,
  "builds": [
    {
      "src": "api/[...slug].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/socket.io/(.*)", "dest": "/api/[...slug]" },
    { "src": "/api/(.*)", "dest": "/api/[...slug]" },
    { "src": "/control", "dest": "/public/control.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
