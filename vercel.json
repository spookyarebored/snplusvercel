{
  "version": 2,
  "builds": [{ "src": "server.js", "use": "@vercel/node" }],
  "routes": [
    { "src": "/control", "dest": "/server.js" },
    { "src": "/api/.*", "dest": "/server.js" },
    { "src": "/socket.io/.*", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
